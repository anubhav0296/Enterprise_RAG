# Copy this file to .env and fill in your own values locally.

PROJECT_ID="your-project-id"
LOCATION="us-central1"
GCP_DOC_AI_LOCATION="us"
GCP_DOC_AI_PROCESSOR_ID="your-processor-id"
GCP_RAW_BUCKET="your-raw-bucket"
GCP_PROCESSED_BUCKET="your-processed-bucket"
VPC_CONNECTOR="rag_vpc"

QDRANT_API_KEY="<your-qdrant-api-key>"
QDRANT_CLUSTER_ENDPOINT="<your-qdrant-endpoint>"

GROQ_API_KEY="<your-groq-api-key>"
GROQ_FALLBACK_API_KEY="<your-groq-fallback-api-key>"

PORTKEY_API_KEY="<your-portkey-api-key>"
PORTKEY_CONFIG_ID="<your-portkey-config-id>"

NVIDIA_API_KEY="<your-nvidia-api-key>"

LOGFIRE_TOKEN="<your-logfire-token>"
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY="<your-langsmith-api-key>"
LANGSMITH_PROJECT="<your-langsmith-project>"

JUDGE_GROQ="<your-judge-groq-key>"
